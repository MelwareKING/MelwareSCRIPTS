local function executeCode(codeText)
    if not codeText or codeText == "" then return end
    if mode == "Server" then
        if RemoteEvent then
            RemoteEvent:FireServer(codeText)
            return
        end
    end

    local func, compileErr = loadstring(codeText)
    if not func then return end
    pcall(func)
end

local function runUrl(name, url)
    local code
    local ok, err = pcall(function() code = game:HttpGet(url) end)
    if not ok or not code then return end
    executeCode(code)
end

local function loadMyMap()
    pcall(function()
        local character = player.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        local origin = root and root.Position or Vector3.new(0, 20, 0)

        local plate = Instance.new("Part")
        plate.Name = "MalwPolaria_MapPlate"
        plate.Anchored = true
        plate.Size = Vector3.new(600, 4, 600)
        plate.Position = Vector3.new(origin.X, origin.Y - 10, origin.Z)
        plate.Color = Color3.fromRGB(0, 80, 0)
        plate.Material = Enum.Material.SmoothPlastic
        plate.Parent = workspace

        local objects = nil
        local gotObjects = pcall(function() objects = game:GetObjects("rbxassetid://111318713256221") end)
        if not gotObjects or not objects or #objects == 0 then
            local asset = InsertService:LoadAsset(111318713256221)
            objects = {asset}
        end

        for _, obj in ipairs(objects) do
            obj.Parent = workspace
            if obj:IsA("Model") then
                obj:PivotTo(CFrame.new(origin.X, origin.Y - 5, origin.Z))
            elseif obj:IsA("BasePart") then
                obj.Anchored = true
                obj.CFrame = CFrame.new(origin.X, origin.Y - 5, origin.Z)
            end
        end
    end)
end

