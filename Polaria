local oldPrint = print
local function stringify(...)
    local result = {}
    for i = 1, select("#", ...) do result[i] = tostring(select(i, ...)) end
    return table.concat(result, "\t")
end

local function hookedPrint(...)
    oldPrint(...)
    appendOutput(stringify(...))
end

if getgenv then getgenv().print = hookedPrint end
