local function getCharacterAndHumanoid()
    local character = player.Character
    if not character then return nil, nil end
    return character, character:FindFirstChildOfClass("Humanoid")
end

local function applyAnimationPack(pack, successMessage)
    local character, humanoid = getCharacterAndHumanoid()
    if not character or not humanoid then return end
    local animate = character:FindFirstChild("Animate")
    if not animate then return end

    for folderName, ids in pairs(pack) do
        local folder = animate:FindFirstChild(folderName)
        if folder then
            local index = 1
            for _, child in ipairs(folder:GetChildren()) do
                if child:IsA("Animation") then
                    child.AnimationId = ids[index] or ids[#ids]
                    index += 1
                end
            end
        end
    end

    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do pcall(function() track:Stop(0.1) end) end
    animate.Disabled = true
    task.wait(0.08)
    animate.Disabled = false
end

