for i, scriptInfo in ipairs(scriptList) do
    local btn = makeOutlineButton(scriptsScroll, scriptInfo.name, UDim2.new(0, 176, 0, 38), UDim2.new())
    btn.LayoutOrder = i
    btn.TextSize = scriptInfo.special and 15 or 13
    btn.TextColor3 = scriptInfo.special and GREEN_TEXT or WHITE
    btn.Font = scriptInfo.special and Enum.Font.GothamBlack or Enum.Font.GothamBold
    btn.MouseButton1Click:Connect(function()
        if scriptInfo.special == "my_script" then
            executeCode(MY_SCRIPT_CODE)
        elseif scriptInfo.special == "my_map" then
            loadMyMap()
        else
            runUrl(scriptInfo.name, scriptInfo.url)
